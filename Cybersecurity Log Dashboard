const express = require("express");
const cors = require("cors");
const fs = require("fs");
const path = require("path");

const app = express();
const PORT = 3000;

// Adjust log path depending on your OS
const logPath = process.platform === "win32" ? "C:\\cyberlog.txt" : "/var/log/cyberlog.txt";

app.use(cors()); // Allow access from GitHub Pages

app.get("/api/logs", (req, res) => {
  fs.readFile(logPath, "utf8", (err, data) => {
    if (err) {
      return res.status(500).send("Unable to read logs.");
    }
    res.type("text/plain").send(data);
  });
});

app.listen(PORT, () => {
  console.log(`Log API running at http://localhost:${PORT}/api/logs`);
});
