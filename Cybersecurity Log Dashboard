<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Cybersecurity Log Dashboard</title>
  <style>
    body { font-family: Arial, sans-serif; background-color: #111; color: #eee; padding: 2rem; }
    h2 { color: #4af; }
    #log { white-space: pre-wrap; background-color: #222; padding: 1rem; border-radius: 5px; max-height: 80vh; overflow-y: auto; }
    .ok { color: #0f0; }
    .warn { color: #ff0; }
    .error { color: #f33; }
  </style>
</head>
<body>
  <h2>Cybersecurity Validation Logs</h2>
  <div id="log">Loading logs...</div>

  <script>
    const apiURL = "https://www.ToronTik.com/api/logs"; // <-- Change if your endpoint is different

    async function fetchLogs() {
      try {
        const res = await fetch(apiURL);
        const text = await res.text();
        const html = text
          .replace(/\[OK\]/g, '<span class="ok">[OK]</span>')
          .replace(/\[!\]/g, '<span class="error">[!]</span>')
          .replace(/\[WARN\]/g, '<span class="warn">[WARN]</span>');
        document.getElementById("log").innerHTML = html;
      } catch (e) {
        document.getElementById("log").textContent = "Error loading logs.";
      }
    }

    setInterval(fetchLogs, 5000);
    fetchLogs();
  </script>
</body>
</html>
